<Window x:Class="RrRpm2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="RadioReference to RPM2" Height="760" Width="1180" MinHeight="640" MinWidth="980"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,4,10,10" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Margin" Value="0,4,10,10" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,4,10,10" />
            <Setter Property="MinHeight" Value="28" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="Margin" Value="0,4,10,10" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,4,16,10" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="TextBlock" x:Key="FieldLabel">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#263238" />
        </Style>
    </Window.Resources>

    <DockPanel Background="#F5F7F9">
        <Border DockPanel.Dock="Top" Background="#FFFFFF" BorderBrush="#D7DEE6" BorderThickness="0,0,0,1" Padding="16,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.15*" />
                    <ColumnDefinition Width="1.15*" />
                    <ColumnDefinition Width="1.15*" />
                    <ColumnDefinition Width="0.8*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="RadioReference username" />
                    <TextBox x:Name="UsernameBox" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Password" />
                    <PasswordBox x:Name="PasswordBox" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="API app key" />
                    <PasswordBox x:Name="AppKeyBox" ToolTip="Paste the app key, or base64:&lt;encoded key&gt;." />
                </StackPanel>
                <StackPanel Grid.Column="3">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Connection" />
                    <Button x:Name="TestConnectionButton" Content="Login" Click="TestConnectionButton_Click" />
                    <CheckBox x:Name="SaveCredentialsBox" Content="Save credentials" />
                    <Button x:Name="ForgetCredentialsButton" Content="Forget" Click="ForgetCredentialsButton_Click" IsEnabled="False" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="RR system SID" />
                    <TextBox x:Name="SidBox" ToolTip="RadioReference trunked system id, usually the sid value in the system URL." />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Lookup by SysID" />
                    <TextBox x:Name="SysIdBox" ToolTip="Optional system identifier, for example a P25 system ID. Use lookup to find RadioReference SID values." />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="2">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Lookup results" />
                    <ComboBox x:Name="SystemResultsBox"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Sid"
                              SelectionChanged="SystemResultsBox_SelectionChanged" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button x:Name="LookupButton" Content="Lookup" Click="LookupButton_Click" />
                    <Button x:Name="LoadButton" Content="Load TGIDs" Click="LoadButton_Click" />
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="0">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Search state" />
                    <ComboBox x:Name="StateSearchBox"
                              DisplayMemberPath="DisplayName"
                              SelectionChanged="StateSearchBox_SelectionChanged"
                              DropDownOpened="StateSearchBox_DropDownOpened"
                              ToolTip="Select a RadioReference state." />
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="1">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Search county" />
                    <ComboBox x:Name="CountySearchBox"
                              DisplayMemberPath="DisplayName"
                              ToolTip="Select a county. Leave blank for statewide systems." />
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="2">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="State/county results" />
                    <TextBlock Foreground="#607D8B" Margin="0,8,10,10" Text="Results appear in Lookup results." />
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="3" VerticalAlignment="Bottom">
                    <Button x:Name="CountySearchButton" Content="Search County" Click="CountySearchButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#FFFFFF" BorderBrush="#D7DEE6" BorderThickness="0,1,0,0" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="#37474F" Text="Ready." />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="ExportButton" Content="Export RPM2 CSV" Click="ExportButton_Click" IsEnabled="False" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="#FFFFFF" BorderBrush="#D7DEE6" BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="0.8*" />
                        <ColumnDefinition Width="0.8*" />
                        <ColumnDefinition Width="0.9*" />
                        <ColumnDefinition Width="1.7*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="RPM2 group set name" />
                        <TextBox x:Name="GroupSetNameBox" Text="RR IMPORT" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="RPM2 system ID" />
                        <TextBox x:Name="RpmSystemIdBox" Text="0x0" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Visual ID color" />
                        <ComboBox x:Name="VisualColorBox" SelectedIndex="0">
                            <ComboBoxItem Content="White" />
                            <ComboBoxItem Content="Yellow" />
                            <ComboBoxItem Content="Green" />
                            <ComboBoxItem Content="Blue" />
                            <ComboBoxItem Content="Red" />
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="3">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Filter text" />
                        <TextBox x:Name="FilterBox" TextChanged="FilterBox_TextChanged" />
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Counties/categories" />
                        <ListBox x:Name="CountyFilterBox"
                                 MinHeight="60"
                                 MaxHeight="96"
                                 Margin="0,4,10,10"
                                 SelectionMode="Extended"
                                 SelectionChanged="CountyFilterBox_SelectionChanged" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="5" Orientation="Horizontal" VerticalAlignment="Bottom">
                        <CheckBox x:Name="IncludeEncryptedBox" Content="Include encrypted" IsChecked="True" Checked="FilterBox_TextChanged" Unchecked="FilterBox_TextChanged" />
                        <StackPanel Width="190" Margin="0,0,16,10">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Long name source" />
                            <ComboBox x:Name="LongNameSourceBox" SelectedIndex="0" Margin="0,4,0,0">
                                <ComboBoxItem Content="Smart" />
                                <ComboBoxItem Content="Alpha" />
                                <ComboBoxItem Content="Description" />
                                <ComboBoxItem Content="Category + Alpha" />
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                    <WrapPanel Grid.Row="2" Grid.ColumnSpan="5" Margin="0,8,0,0">
                        <CheckBox x:Name="TransmitBox" Content="Transmit" IsChecked="False" />
                        <CheckBox x:Name="ReceiveBox" Content="Receive" IsChecked="True" />
                        <CheckBox x:Name="CallsBox" Content="Calls" IsChecked="True" />
                        <CheckBox x:Name="ScanBox" Content="Scan" IsChecked="True" />
                        <CheckBox x:Name="AlertTonesBox" Content="Alert tones" IsChecked="True" />
                        <CheckBox x:Name="BacklightBox" Content="Backlight" IsChecked="True" />
                        <CheckBox x:Name="ScanListMemberBox" Content="Scan list member" IsChecked="True" />
                        <CheckBox x:Name="ConventionalFallbackBox" Content="Conv fallback" IsChecked="False" />
                        <CheckBox x:Name="UseGroupIdZeroBox" Content="Use group ID 0" IsChecked="False" />
                        <CheckBox x:Name="SuppressKeyNumberBox" Content="Suppress key number" IsChecked="False" />
                        <CheckBox x:Name="EncryptCallParametersBox" Content="Encrypt call params" IsChecked="False" />
                        <CheckBox x:Name="MandownBox" Content="Mandown" IsChecked="False" />
                    </WrapPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="#D7DEE6" BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Sites/control channels" />
                        <ListBox x:Name="SitesBox"
                                 MinHeight="72"
                                 MaxHeight="132"
                                 Margin="0,4,10,0"
                                 DisplayMemberPath="DisplayName"
                                 SelectionMode="Extended" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="TX fallback" />
                        <TextBox x:Name="SiteTransmitPlaceholderBox" Text="763.00000" ToolTip="Fallback dummy transmit frequency; export uses the matching receive-frequency bank when possible." />
                        <CheckBox x:Name="ExportAllSitesIfNoneSelectedBox" Content="All sites if none selected" IsChecked="True" />
                        <Button x:Name="ExportSitesButton" Content="Export Site CSV" Click="ExportSitesButton_Click" IsEnabled="False" />
                    </StackPanel>
                </Grid>
            </Border>

            <DataGrid x:Name="TalkgroupsGrid"
                      Grid.Row="2"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      EnableRowVirtualization="True"
                      GridLinesVisibility="Horizontal"
                      Background="#FFFFFF"
                      BorderBrush="#D7DEE6"
                      BorderThickness="1"
                      AlternatingRowBackground="#F8FAFC">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="TGID" Binding="{Binding DecimalId}" Width="90" />
                    <DataGridTextColumn Header="Alpha" Binding="{Binding Alpha}" Width="140" />
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="2*" />
                    <DataGridTextColumn Header="Mode" Binding="{Binding Mode}" Width="70" />
                    <DataGridCheckBoxColumn Header="Encrypted" Binding="{Binding IsEncrypted, Mode=OneWay}" Width="90" />
                    <DataGridTextColumn Header="Category" Binding="{Binding CategoryName}" Width="180" />
                    <DataGridTextColumn Header="Tag" Binding="{Binding TagSummary}" Width="160" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </DockPanel>
</Window>
