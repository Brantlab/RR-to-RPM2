<Window x:Class="RrRpm2.TelemetryPrivacyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Privacy &amp; Usage Statistics"
        Width="540"
        Height="445"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <Border Padding="24" Background="#F5F7F9">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="HeadingText"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="#263238"
                       Text="Help improve RR to RPM2" />

            <StackPanel Grid.Row="1" Margin="0,18,0,16">
                <TextBlock TextWrapping="Wrap"
                           Text="If you allow it, the app sends anonymous usage statistics to BrantLab's self-hosted telemetry service:" />
                <TextBlock Margin="14,12,0,0" Text="• App version, Windows version, and architecture" />
                <TextBlock Margin="14,5,0,0" Text="• App launches, update checks, and successful export counts" />
                <TextBlock Margin="14,5,0,0" Text="• Exception type when the app encounters an unexpected error" />
                <TextBlock Margin="0,16,0,0"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Text="It never sends RadioReference credentials, API keys, system or talkgroup IDs, filenames, CSV contents, or exception messages." />
                <TextBlock Margin="0,16,0,0"
                           TextWrapping="Wrap"
                           Text="You can change your choice anytime from Help → Privacy &amp; Usage Statistics." />
            </StackPanel>

            <CheckBox x:Name="EnabledCheckBox"
                      Grid.Row="2"
                      Margin="0,0,0,14"
                      FontWeight="SemiBold"
                      Content="Share anonymous usage statistics"
                      Visibility="Collapsed" />

            <StackPanel Grid.Row="3"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                <Button x:Name="SecondaryButton"
                        MinWidth="100"
                        Margin="0,0,10,0"
                        Padding="10,5"
                        Content="No thanks"
                        Click="SecondaryButton_Click" />
                <Button x:Name="PrimaryButton"
                        MinWidth="170"
                        Padding="10,5"
                        IsDefault="True"
                        Content="Allow anonymous statistics"
                        Click="PrimaryButton_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
